                    </div>
                    <div style="background: #e2e8f0; border-radius: 9999px; height: 8px; overflow: hidden;">
                        <div style="width: <?php echo $progress; ?>%; background: linear-gradient(90deg, #2563eb, #3b82f6); height: 100%; border-radius: 9999px;"></div>
