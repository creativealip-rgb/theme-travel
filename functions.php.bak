<?php
/**
 * Contenly Theme functions and definitions
 *
 * @package Contenly_Theme
 * @since 1.0.0
 */

if ( ! defined( 'ABSPATH' ) ) {
    exit; // Exit if accessed directly
}

/**
 * Define theme constants
 */
define( 'CONTENLY_VERSION', '1.0.0' );
define( 'CONTENLY_DIR', get_template_directory() );
define( 'CONTENLY_URI', get_template_directory_uri() );

/**
 * Load Payment Gateway (Midtrans - Optional)
 */
// require_once CONTENLY_DIR . '/midtrans-gateway.php';
// require_once CONTENLY_DIR . '/payment-handler.php';

/**
 * Load Manual Payment Handler
 */
require_once CONTENLY_DIR . '/manual-payment-handler.php';
require_once CONTENLY_DIR . '/simple-admin-menu.php';

/**
 * Redirect after login
 */
add_filter('login_redirect', 'contenly_login_redirect', 10, 3);
function contenly_login_redirect($redirect_to, $request, $user) {
    // Redirect to Dashboard page after login
    return home_url('/dashboard/');
}

/**
 * Theme Setup
 */
function contenly_theme_setup() {
    /*
     * Make theme available for translation.
     */
    load_theme_textdomain( 'contenly-theme', CONTENLY_DIR . '/languages' );

    /*
     * Add default posts and comments RSS feed links to head.
     */
    add_theme_support( 'automatic-feed-links' );

    /*
     * Let WordPress manage the document title.
     */
    add_theme_support( 'title-tag' );

    /*
     * Enable support for Post Thumbnails on posts and pages.
     */
    add_theme_support( 'post-thumbnails' );
    set_post_thumbnail_size( 1200, 675, true );
    add_image_size( 'contenly-large', 1200, 675, true );
    add_image_size( 'contenly-medium', 800, 450, true );
    add_image_size( 'contenly-small', 400, 225, true );

    /*
     * Register navigation menus.
     */
    register_nav_menus( array(
        'primary'   => __( 'Primary Menu', 'contenly-theme' ),
        'footer'    => __( 'Footer Menu', 'contenly-theme' ),
        'mobile'    => __( 'Mobile Menu', 'contenly-theme' ),
    ) );

    /*
     * Switch default core markup to output valid HTML5.
     */
    add_theme_support( 'html5', array(
        'search-form',
        'comment-form',
        'comment-list',
        'gallery',
        'caption',
        'style',
        'script',
    ) );

    /*
     * Set up the WordPress core custom background feature.
     */
    add_theme_support( 'custom-background', array(
        'default-color' => 'fafafa',
        'default-image' => '',
    ) );

    /*
     * Add theme support for selective refresh for widgets.
     */
    add_theme_support( 'customize-selective-refresh-widgets' );

    /*
     * Support for core custom logo.
     */
    add_theme_support( 'custom-logo', array(
        'height'      => 100,
        'width'       => 300,
        'flex-height' => true,
        'flex-width'  => true,
    ) );

    /*
     * Support for wide alignment.
     */
    add_theme_support( 'align-wide' );

    /*
     * Support for responsive embeds.
     */
    add_theme_support( 'responsive-embeds' );

    /*
     * Support for editor styles.
     */
    add_theme_support( 'editor-styles' );
    add_editor_style( 'assets/css/editor-style.css' );

    /*
     * Support for WooCommerce.
     */
    add_theme_support( 'woocommerce' );
    add_theme_support( 'wc-product-gallery-zoom' );
    add_theme_support( 'wc-product-gallery-lightbox' );
    add_theme_support( 'wc-product-gallery-slider' );
}
add_action( 'after_setup_theme', 'contenly_theme_setup' );

/**
 * Set the content width in pixels.
 */
function contenly_theme_content_width() {
    $GLOBALS['content_width'] = apply_filters( 'contenly_content_width', 1200 );
}
add_action( 'after_setup_theme', 'contenly_theme_content_width', 0 );

/**
 * Register widget area.
 */
function contenly_theme_widgets_init() {
    register_sidebar( array(
        'name'          => __( 'Sidebar', 'contenly-theme' ),
        'id'            => 'sidebar-1',
        'description'   => __( 'Add widgets here.', 'contenly-theme' ),
        'before_widget' => '<section id="%1$s" class="widget %2$s">',
        'after_widget'  => '</section>',
        'before_title'  => '<h2 class="widget-title">',
        'after_title'   => '</h2>',
    ) );

    register_sidebar( array(
        'name'          => __( 'Footer', 'contenly-theme' ),
        'id'            => 'footer-1',
        'description'   => __( 'Add footer widgets here.', 'contenly-theme' ),
        'before_widget' => '<div id="%1$s" class="footer-widget %2$s">',
        'after_widget'  => '</div>',
        'before_title'  => '<h3 class="footer-widget-title">',
        'after_title'   => '</h3>',
    ) );
}
add_action( 'widgets_init', 'contenly_theme_widgets_init' );

/**
 * Enqueue scripts and styles.
 */
function contenly_theme_scripts() {
    // Google Fonts
    wp_enqueue_style( 'contenly-fonts', 'https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap', array(), null );

    // Main stylesheet
    wp_enqueue_style( 'contenly-style', get_stylesheet_uri(), array(), CONTENLY_VERSION );

    // Custom CSS (only if exists)
    if ( file_exists( CONTENLY_DIR . '/assets/css/custom.css' ) ) {
        wp_enqueue_style( 'contenly-custom', CONTENLY_URI . '/assets/css/custom.css', array(), CONTENLY_VERSION );
    }

    // Main JavaScript
    wp_enqueue_script( 'contenly-main', CONTENLY_URI . '/assets/js/main.js', array(), CONTENLY_VERSION, true );

    // Navigation JavaScript (only if exists)
    if ( file_exists( CONTENLY_DIR . '/assets/js/navigation.js' ) ) {
        wp_enqueue_script( 'contenly-navigation', CONTENLY_URI . '/assets/js/navigation.js', array(), CONTENLY_VERSION, true );
    }

    // Comment reply script
    if ( is_singular() && comments_open() && get_option( 'thread_comments' ) ) {
        wp_enqueue_script( 'comment-reply' );
    }

    // Preload critical resources
    wp_resource_hints( 'https://fonts.googleapis.com', 'preconnect' );
    wp_resource_hints( 'https://fonts.gstatic.com', 'preconnect' );
}
add_action( 'wp_enqueue_scripts', 'contenly_theme_scripts' );

/**
 * Custom template tags for this theme.
 */
require CONTENLY_DIR . '/inc/template-tags.php';

/**
 * Functions which enhance the theme by hooking into WordPress.
 */
require CONTENLY_DIR . '/inc/template-functions.php';

/**
 * Customizer additions.
 */
if ( file_exists( CONTENLY_DIR . '/inc/customizer.php' ) ) {
    require CONTENLY_DIR . '/inc/customizer.php';
}

/**
 * Load Jetpack compatibility file.
 */
if ( defined( 'JETPACK__VERSION' ) && file_exists( CONTENLY_DIR . '/inc/jetpack.php' ) ) {
    require CONTENLY_DIR . '/inc/jetpack.php';
}

/**
 * WooCommerce Customization.
 */
if ( class_exists( 'WooCommerce' ) && file_exists( CONTENLY_DIR . '/inc/woocommerce.php' ) ) {
    require CONTENLY_DIR . '/inc/woocommerce.php';
}

/**
 * Custom excerpt length
 */
function contenly_excerpt_length( $length ) {
    if ( is_admin() ) {
        return $length;
    }
    return 25;
}
add_filter( 'excerpt_length', 'contenly_excerpt_length' );

/**
 * Custom excerpt more
 */
function contenly_excerpt_more( $more ) {
    if ( is_admin() ) {
        return $more;
    }
    return '...';
}
add_filter( 'excerpt_more', 'contenly_excerpt_more' );

/**
 * Add custom body classes
 */
function contenly_body_classes( $classes ) {
    if ( ! is_singular() ) {
        $classes[] = 'hfeed';
    }

    if ( is_front_page() ) {
        $classes[] = 'front-page';
    }

    return $classes;
}
add_filter( 'body_class', 'contenly_body_classes' );

/**
 * Add a pingback url auto-discovery header
 */
function contenly_pingback_header() {
    if ( is_singular() && pings_open() ) {
        printf( '<link rel="pingback" href="%s">', esc_url( get_bloginfo( 'pingback_url' ) ) );
    }
}
add_action( 'wp_head', 'contenly_pingback_header' );
